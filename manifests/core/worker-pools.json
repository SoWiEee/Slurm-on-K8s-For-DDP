{
  "controller": {
    "name": "slurm-controller",
    "service": "slurm-controller",
    "replicas": 1,
    "image": "slurm-controller:latest"
  },
  "workerPools": [
    {
      "name": "slurm-worker-cpu",
      "service": "slurm-worker-cpu",
      "appLabel": "slurm-worker-cpu",
      "workerClass": "cpu-standard",
      "image": "slurm-worker:latest",
      "maxNodes": 4,
      "replicas": 1,
      "cpus": 4,
      "realMemory": 3500,
      "sockets": 1,
      "coresPerSocket": 2,
      "threadsPerCore": 2,
      "features": [
        "cpu"
      ],
      "gres": []
    },
    {
      "name": "slurm-worker-gpu-a10",
      "service": "slurm-worker-gpu-a10",
      "appLabel": "slurm-worker-gpu-a10",
      "workerClass": "gpu-a10",
      "image": "slurm-worker:latest",
      "maxNodes": 4,
      "replicas": 0,
      "cpus": 4,
      "realMemory": 3500,
      "sockets": 1,
      "coresPerSocket": 2,
      "threadsPerCore": 2,
      "features": [
        "gpu",
        "gpu-a10"
      ],
      "gres": [
        "gpu:a10:1"
      ]
    },
    {
      "name": "slurm-worker-gpu-h100",
      "service": "slurm-worker-gpu-h100",
      "appLabel": "slurm-worker-gpu-h100",
      "workerClass": "gpu-h100",
      "image": "slurm-worker:latest",
      "maxNodes": 4,
      "replicas": 0,
      "cpus": 4,
      "realMemory": 3500,
      "sockets": 1,
      "coresPerSocket": 2,
      "threadsPerCore": 2,
      "features": [
        "gpu",
        "gpu-h100"
      ],
      "gres": [
        "gpu:h100:1"
      ]
    }
  ],
  "partition": {
    "name": "debug",
    "default": true,
    "maxTime": "INFINITE",
    "state": "UP"
  }
}
