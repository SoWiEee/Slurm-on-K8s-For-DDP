{
  "controller": {
    "name": "slurm-controller",
    "service": "slurm-controller",
    "replicas": 1,
    "image": "slurm-controller:latest"
  },
  "workerPools": [
    {
      "name": "slurm-worker-cpu",
      "service": "slurm-worker-cpu",
      "appLabel": "slurm-worker-cpu",
      "workerClass": "cpu-standard",
      "image": "slurm-worker:latest",
      "maxNodes": 4,
      "replicas": 1,
      "cpus": 4,
      "realMemory": 3500,
      "sockets": 1,
      "coresPerSocket": 2,
      "threadsPerCore": 2,
      "features": [
        "cpu"
      ],
      "gres": []
    },
    {
      "name": "slurm-worker-gpu-rtx5070",
      "service": "slurm-worker-gpu-rtx5070",
      "appLabel": "slurm-worker-gpu-rtx5070",
      "workerClass": "gpu-rtx5070",
      "image": "slurm-worker:latest",
      "maxNodes": 2,
      "replicas": 0,
      "cpus": 4,
      "realMemory": 3500,
      "sockets": 1,
      "coresPerSocket": 2,
      "threadsPerCore": 2,
      "features": [
        "gpu",
        "gpu-rtx5070"
      ],
      "gres": [
        "gpu:rtx5070:1",
        "mps:100"
      ],
      "devicePath": "/dev/nvidia0"
    },
    {
      "name": "slurm-worker-gpu-rtx4080",
      "service": "slurm-worker-gpu-rtx4080",
      "appLabel": "slurm-worker-gpu-rtx4080",
      "workerClass": "gpu-rtx4080",
      "image": "slurm-worker:latest",
      "maxNodes": 2,
      "replicas": 0,
      "cpus": 4,
      "realMemory": 3500,
      "sockets": 1,
      "coresPerSocket": 2,
      "threadsPerCore": 2,
      "features": [
        "gpu",
        "gpu-rtx4080"
      ],
      "gres": [
        "gpu:rtx4080:1"
      ],
      "devicePath": "/dev/nvidia1"
    }
  ],
  "partition": {
    "name": "debug",
    "default": true,
    "maxTime": "INFINITE",
    "state": "UP"
  }
}
