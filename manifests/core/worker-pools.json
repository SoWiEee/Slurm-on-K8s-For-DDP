{
  "controller": {
    "name": "slurm-controller",
    "service": "slurm-controller",
    "replicas": 1,
    "image": "slurm-controller:latest"
  },
  "workerPools": [
    {
      "name": "slurm-worker-cpu",
      "service": "slurm-worker-cpu",
      "appLabel": "slurm-worker-cpu",
      "workerClass": "cpu-standard",
      "image": "slurm-worker:latest",
      "partition": "cpu",
      "maxNodes": 4,
      "replicas": 1,
      "cpus": 4,
      "realMemory": 3500,
      "sockets": 1,
      "coresPerSocket": 2,
      "threadsPerCore": 2,
      "features": [
        "cpu"
      ],
      "gres": []
    },
    {
      "name": "slurm-worker-gpu-rtx4070",
      "service": "slurm-worker-gpu-rtx4070",
      "appLabel": "slurm-worker-gpu-rtx4070",
      "workerClass": "gpu-rtx4070",
      "image": "slurm-worker:latest",
      "partition": "gpu-rtx4070",
      "maxNodes": 2,
      "replicas": 0,
      "cpus": 4,
      "realMemory": 3500,
      "sockets": 1,
      "coresPerSocket": 2,
      "threadsPerCore": 2,
      "features": [
        "gpu",
        "gpu-rtx4070"
      ],
      "gres": [
        "gpu:rtx4070:1",
        "mps:100"
      ]
    },
    {
      "name": "slurm-worker-gpu-rtx4080",
      "service": "slurm-worker-gpu-rtx4080",
      "appLabel": "slurm-worker-gpu-rtx4080",
      "workerClass": "gpu-rtx4080",
      "image": "slurm-worker:latest",
      "partition": "gpu-rtx4080",
      "maxNodes": 2,
      "replicas": 0,
      "cpus": 4,
      "realMemory": 3500,
      "sockets": 1,
      "coresPerSocket": 2,
      "threadsPerCore": 2,
      "features": [
        "gpu",
        "gpu-rtx4080"
      ],
      "gres": [
        "gpu:rtx4080:1"
      ]
    }
  ],
  "partitions": [
    {
      "name": "cpu",
      "default": true,
      "maxTime": "INFINITE",
      "state": "UP"
    },
    {
      "name": "gpu-rtx4070",
      "default": false,
      "maxTime": "INFINITE",
      "state": "UP"
    },
    {
      "name": "gpu-rtx4080",
      "default": false,
      "maxTime": "INFINITE",
      "state": "UP"
    }
  ]
}
