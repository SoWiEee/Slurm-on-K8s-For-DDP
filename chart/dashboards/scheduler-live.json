{
  "uid": "slurm-scheduler-live",
  "title": "Scheduler Live Resource View",
  "description": "Visual operational view for Slurm queue, DSAC decisions, MPS slots, GPU use, and worker capacity.",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "tags": [
    "slurm",
    "scheduler",
    "dsac",
    "mps"
  ],
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
