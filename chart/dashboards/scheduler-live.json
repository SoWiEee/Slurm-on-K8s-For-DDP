      "id": 1,
      "type": "text",
      "title": "Resource Flow",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 5
      },
      "options": {
        "mode": "html",
        "content": "\n<div style='display:flex;gap:10px;align-items:center;justify-content:space-between;font-family:Inter,Arial,sans-serif;'>\n  <div style='flex:1;padding:14px;border:1px solid #64748b;border-radius:8px;background:#0f172a;color:#e2e8f0;text-align:center;'><div style='font-size:20px;'>Submit</div><div>sbatch job enters Slurm</div></div>\n  <div style='font-size:28px;color:#94a3b8;'>\u2192</div>\n  <div style='flex:1;padding:14px;border:1px solid #2563eb;border-radius:8px;background:#172554;color:#dbeafe;text-align:center;'><div style='font-size:20px;'>DSAC</div><div>selects job / node / GPU</div></div>\n  <div style='font-size:28px;color:#94a3b8;'>\u2192</div>\n  <div style='flex:1;padding:14px;border:1px solid #16a34a;border-radius:8px;background:#052e16;color:#dcfce7;text-align:center;'><div style='font-size:20px;'>Priority</div><div>boost applied to queue</div></div>\n  <div style='font-size:28px;color:#94a3b8;'>\u2192</div>\n  <div style='flex:1;padding:14px;border:1px solid #ca8a04;border-radius:8px;background:#422006;color:#fef3c7;text-align:center;'><div style='font-size:20px;'>Workers</div><div>CPU / GPU / MPS slots run jobs</div></div>\n</div>\n"
      }
